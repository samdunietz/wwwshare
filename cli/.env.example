# Local development: copy this file to cli/.env (gitignored).
# Installed-CLI use: put the same vars in ~/.config/wwwshare/.env so
# `wwwshare` from anywhere on your PATH picks them up.
# Shell env (e.g. `export WWWSHARE_UPLOAD_TOKEN=...`) wins over both.
WWWSHARE_ENDPOINT=http://localhost:8787
WWWSHARE_UPLOAD_TOKEN=devtoken
